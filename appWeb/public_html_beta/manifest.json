  "share_target": {
    "action": "index.php",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "related_applications": [
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/ihymns/id0000000000"
    },
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=ltd.mwbmpartners.ihymns"
    },
    {
      "platform": "amazon",
      "url": "https://www.amazon.com/dp/B0000000000"
    }
  ],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "index.php",
      "accept": {
        "text/plain": [".txt"],
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+ihymns",
      "url": "index.php?song=%s"
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://ihymns.app"
    }
  ]
}
