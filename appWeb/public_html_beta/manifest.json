{
    "_comment": "iHymns — PWA Web App Manifest. Comprehensive configuration using all available parameters including experimental ones.",

    "id": "ltd.mwbmpartners.ihymns.pwa",
    "name": "iHymns — Christian Hymns & Worship Songs",
    "short_name": "iHymns",
    "description": "A multiplatform Christian lyrics application providing searchable hymn and worship song lyrics from multiple songbooks, designed to enhance worship. Features 5 songbooks with over 3,600 songs, full-text search, favourites, dark mode, high-contrast mode, and offline support.",
    "version": "0.1.5",

    "start_url": "/",
    "scope": "/",
    "display": "standalone",
    "display_override": [
        "window-controls-overlay",
        "standalone",
        "minimal-ui"
    ],
    "orientation": "any",

    "theme_color": "#4f46e5",
    "background_color": "#f8fafc",

    "lang": "en",
    "dir": "ltr",

    "categories": [
        "books",
        "education",
        "lifestyle",
        "music",
        "reference",
        "utilities"
    ],

    "iarc_rating_id": "",

    "prefer_related_applications": false,
    "related_applications": [],

    "icons": [
        {
            "src": "/assets/favicon.svg",
            "type": "image/svg+xml",
            "sizes": "any",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-48.png",
            "type": "image/png",
            "sizes": "48x48",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-72.png",
            "type": "image/png",
            "sizes": "72x72",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-96.png",
            "type": "image/png",
            "sizes": "96x96",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-128.png",
            "type": "image/png",
            "sizes": "128x128",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-144.png",
            "type": "image/png",
            "sizes": "144x144",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-152.png",
            "type": "image/png",
            "sizes": "152x152",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-192.png",
            "type": "image/png",
            "sizes": "192x192",
            "purpose": "any maskable"
        },
        {
            "src": "/assets/icon-256.png",
            "type": "image/png",
            "sizes": "256x256",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-384.png",
            "type": "image/png",
            "sizes": "384x384",
            "purpose": "any"
        },
        {
            "src": "/assets/icon-512.png",
            "type": "image/png",
            "sizes": "512x512",
            "purpose": "any maskable"
        }
    ],

    "screenshots": [
        {
            "src": "/assets/screenshots/home-wide.png",
            "type": "image/png",
            "sizes": "1280x720",
            "form_factor": "wide",
            "label": "iHymns home screen on desktop"
        },
        {
            "src": "/assets/screenshots/song-detail-wide.png",
            "type": "image/png",
            "sizes": "1280x720",
            "form_factor": "wide",
            "label": "Song lyrics view on desktop"
        },
        {
            "src": "/assets/screenshots/home-narrow.png",
            "type": "image/png",
            "sizes": "390x844",
            "form_factor": "narrow",
            "label": "iHymns home screen on mobile"
        },
        {
            "src": "/assets/screenshots/song-detail-narrow.png",
            "type": "image/png",
            "sizes": "390x844",
            "form_factor": "narrow",
            "label": "Song lyrics view on mobile"
        }
    ],

    "shortcuts": [
        {
            "name": "Search Songs",
            "short_name": "Search",
            "description": "Search for hymns and worship songs",
            "url": "/search",
            "icons": [
                {
                    "src": "/assets/icon-search.png",
                    "sizes": "96x96",
                    "type": "image/png"
                }
            ]
        },
        {
            "name": "Favourites",
            "short_name": "Favourites",
            "description": "View your favourite songs",
            "url": "/favorites",
            "icons": [
                {
                    "src": "/assets/icon-star.png",
                    "sizes": "96x96",
                    "type": "image/png"
                }
            ]
        },
        {
            "name": "Songbooks",
            "short_name": "Books",
            "description": "Browse all songbooks",
            "url": "/songbooks",
            "icons": [
                {
                    "src": "/assets/icon-book.png",
                    "sizes": "96x96",
                    "type": "image/png"
                }
            ]
        },
        {
            "name": "Help",
            "short_name": "Help",
            "description": "Get help using iHymns",
            "url": "/help",
            "icons": [
                {
                    "src": "/assets/icon-help.png",
                    "sizes": "96x96",
                    "type": "image/png"
                }
            ]
        }
    ],

    "share_target": {
        "action": "/search",
        "method": "GET",
        "params": {
            "text": "q",
            "title": "q",
            "url": "q"
        }
    },

    "protocol_handlers": [
        {
            "protocol": "web+ihymns",
            "url": "/song/%s"
        }
    ],

    "file_handlers": [
        {
            "action": "/",
            "accept": {
                "application/json": [".json"],
                "text/plain": [".txt"]
            }
        }
    ],

    "note_taking": {
        "new_note_url": "/favorites"
    },

    "handle_links": "preferred",

    "launch_handler": {
        "client_mode": ["navigate-existing", "auto"]
    },

    "scope_extensions": [
        {
            "origin": "https://ihymns.app"
        },
        {
            "origin": "https://www.ihymns.app"
        }
    ],

    "edge_side_panel": {
        "preferred_width": 400
    },

    "serviceworker": {
        "src": "/service-worker.js",
        "scope": "/",
        "type": "classic",
        "update_via_cache": "none"
    }
}
