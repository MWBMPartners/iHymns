# ==========================================================================
# iHymns — Apache Configuration (.htaccess)
#
# Copyright (c) 2026 MWBM Partners Ltd. All rights reserved.
#
# PURPOSE:
# Handles URL rewriting for clean URLs (no .php extensions visible),
# API routing, GZIP compression, security headers, caching, and
# proper MIME type configuration.
#
# CLEAN URL STRATEGY:
#   - All navigation URLs (/, /song/CP-0001, /songbooks, etc.) are
#     rewritten to index.php for server-side rendering of OG meta tags
#     and client-side SPA routing via pushState.
#   - The API endpoint is accessed via /api (rewritten to api.php).
#   - Direct access to .php files is blocked (security: hides PHP).
#   - Static assets (CSS, JS, images, fonts) are served directly.
# ==========================================================================

# Enable the rewrite engine
RewriteEngine On

# ==========================================================================
# BLOCK DIRECT ACCESS TO PHP FILES
#
# Security measure: prevents revealing that the server uses PHP.
# All PHP files must be accessed through clean URL rewrites.
# Exceptions: none — all PHP access goes through rewritten paths.
# ==========================================================================

# Block direct access to any .php file (except internal rewrites)
RewriteCond %{THE_REQUEST} \.php[\s?/] [NC]
RewriteRule ^ - [R=404,L]

# ==========================================================================
# BLOCK ACCESS TO SENSITIVE FILES & DIRECTORIES
# ==========================================================================

# Block access to the includes directory entirely
RewriteRule ^includes/ - [F,L]

# Block access to hidden files (e.g., .gitkeep, .env)
RewriteRule (^|/)\.(?!well-known) - [F,L]

# ==========================================================================
# API ROUTING
#
# /api?param=value → api.php?param=value
# Passes all query string parameters through transparently.
# ==========================================================================

RewriteRule ^api$ api.php [QSA,L]

# ==========================================================================
# STATIC ASSET PASSTHROUGH
#
# Allow direct access to static files (CSS, JS, images, fonts, data).
# These do NOT get rewritten to index.php.
# ==========================================================================

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ==========================================================================
# SPA CATCH-ALL — Rewrite all other requests to index.php
#
# This handles all clean URL navigation:
#   /              → index.php (home)
#   /songbooks     → index.php (JS router handles the route)
#   /songbook/CP   → index.php (JS router handles the route)
#   /song/CP-0001  → index.php (OG meta tags + JS routing)
#   /search        → index.php
#   /favorites     → index.php
#   /settings      → index.php
#   /help          → index.php
#   /terms         → index.php
#   /privacy       → index.php
#
# index.php reads the URL path for dynamic OG meta tags (share links),
# then the JavaScript SPA router takes over for client-side navigation.
# ==========================================================================

RewriteRule ^ index.php [QSA,L]

# ==========================================================================
# MIME TYPES — Ensure correct Content-Type headers
# ==========================================================================

<IfModule mod_mime.c>
    # JavaScript modules
    AddType text/javascript .js .mjs

    # JSON
    AddType application/json .json

    # Web App Manifest
    AddType application/manifest+json .json

    # SVG
    AddType image/svg+xml .svg .svgz
    AddEncoding gzip .svgz

    # Fonts
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType application/font-sfnt .ttf
    AddType application/vnd.ms-fontobject .eot

    # MIDI audio
    AddType audio/midi .mid .midi

    # PDF
    AddType application/pdf .pdf

    # Web manifest (explicit)
    AddType application/manifest+json manifest.json
</IfModule>

# ==========================================================================
# GZIP COMPRESSION — Reduce transfer sizes
# ==========================================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/manifest+json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE application/font-sfnt
</IfModule>

# ==========================================================================
# CACHE CONTROL
#
# Beta: aggressive no-cache to ensure fresh content during development.
# Production: these would be set to longer cache durations.
# ==========================================================================

<IfModule mod_headers.c>
    # Service worker — never cache (must always be fresh)
    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Manifest — short cache
    <FilesMatch "manifest\.json$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # HTML/PHP output — no cache in beta
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # CSS and JS — short cache in beta
    <FilesMatch "\.(css|js|mjs)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    # Images and fonts — longer cache
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|woff2|woff|ttf|eot)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>

    # JSON data — short cache
    <FilesMatch "songs\.json$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

# ==========================================================================
# SECURITY HEADERS
# ==========================================================================

<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # XSS Protection (legacy browsers)
    Header set X-XSS-Protection "1; mode=block"

    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Referrer policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy — disable unnecessary APIs
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

    # HSTS — Enforce HTTPS (1 year, include subdomains)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Cross-Origin policies
    Header set Cross-Origin-Opener-Policy "same-origin"
    Header set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

# ==========================================================================
# ERROR HANDLING — Custom 404 redirects to the SPA shell
# ==========================================================================

ErrorDocument 404 /index.php
