# iHymns — Deny all web access to shared data directory
# This directory is outside the public web root but this .htaccess
# provides defense-in-depth in case of misconfiguration.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Block all file types
<FilesMatch ".*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
