{
  "name": "ihymns",
  "version": "1.0.0-alpha.1",
  "description": "iHymns — A multiplatform Christian lyrics application for worship enhancement",
  "private": true,
  "type": "module",
  "scripts": {
    "parse-songs": "node tools/parse-songs.js",
    "build:web": "node tools/build-web.js",
    "build:web:production": "node tools/build-web.js --target production",
    "build:web:beta": "node tools/build-web.js --target beta",
    "build:web:dev": "node tools/build-web.js --target dev",
    "predev": "mkdir -p appWeb/data_share/song_data appWeb/data_share/setlist_json appWeb/private_html/data && cp data/songs.json appWeb/data_share/song_data/songs.json && cp data/songs.json appWeb/private_html/data/songs.json",
    "dev": "php -S localhost:8000 -t appWeb/public_html",
    "preview": "php -S localhost:8080 -t dist/web",
    "lint:js": "eslint appWeb/public_html/js/",
    "lint:css": "stylelint appWeb/public_html/css/**/*.css",
    "lint:html": "htmlhint appWeb/public_html/**/*.html",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "format": "prettier --write appWeb/public_html/",
    "test": "node tests/test-song-parser.js",
    "test:php": "find appWeb -name '*.php' -exec php -l {} \\;",
    "test:js": "find appWeb -name '*.js' -not -path '*/node_modules/*' -exec node --check {} \\;",
    "test:all": "npm test && npm run test:php && npm run test:js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MWBMPartners/iHymns.git"
  },
  "author": "iHymns",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/MWBMPartners/iHymns/issues"
  },
  "homepage": "https://ihymns.app",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
