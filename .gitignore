# ----------------------------------------------------------------------------
# Database Credentials (appWeb/.auth/)
# The real credentials file is never committed; only the example template.
# ----------------------------------------------------------------------------
appWeb/.auth/*
!appWeb/.auth/.htaccess
!appWeb/.auth/db_credentials.example.php

# ----------------------------------------------------------------------------
# Secrets / Credentials (NEVER commit these)
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json
sftp-config.json
.htpasswd
.htpasswd-*

# ----------------------------------------------------------------------------
# Generated Data (re-generated from .SourceSongData/)
# ----------------------------------------------------------------------------
# Canonical songs.json is still tracked in data/ (generated by parse-songs.js).
# The runtime copy in data_share/ and deploy copies are excluded.
appWeb/data_share/song_data/songs.json
appWeb/data_share/setlist_json/*.json
appWeb/data/songs.json
appWeb/public_html/data/songs.json
appWeb/private_html/data/songs.json

# CI/CD injected environment channel file (deploy-time only)
appWeb/public_html/.env-channel

# ----------------------------------------------------------------------------
# Vendor libraries — generated by tools/download-vendor.sh (#354 / #526)
# ----------------------------------------------------------------------------
# Bootstrap, FontAwesome, jQuery, Animate.css, Fuse.js, Tone.js, PDF.js
# downloaded as PWA offline-fallback for the onerror handlers in index.php.
# Re-generated on every deploy by deploy.yml; do not commit.
appWeb/public_html/vendor/

# ----------------------------------------------------------------------------
# Source Scraped Song data
# ----------------------------------------------------------------------------
.SourceSongData/*
*_debug_*_raw.html
*_debug_*_skipped.html
